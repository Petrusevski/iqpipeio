generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String?
  firstLoginAt DateTime? // null = never logged in; set on first successful login
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships   WorkspaceUser[]
  notifications Notification[]
}

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // ── Workspace-level settings ───────────────────────────────
  companyName         String?
  primaryDomain       String?
  defaultCurrency     String  @default("EUR") // "EUR", "USD", "GBP"
  timezone            String  @default("Europe/Prague")
  industry            String  @default("SaaS") // for benchmarks

  plan                String  @default("trial") // "trial" | "free" | "starter" | "growth" | "agency"
  trialEndsAt         DateTime?
  seatsTotal          Int     @default(5)
  seatsUsed           Int     @default(1)
  billingEmail        String?

  // ── Stripe billing ─────────────────────────────────────────────────────────
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  revenuelaIdPrefix   String  @default("RVN-LEAD-")
  publicApiKey        String  @default("")
  webhookEndpoint     String  @default("")

  dataAnonymization   Boolean @default(false)
  dataRetentionMonths Int     @default(12)
  isDemo              Boolean @default(false)
  eventCountMonth     Int       @default(0)
  eventCountResetAt   DateTime?
  eventCountMinute    Int       @default(0)
  rateLimitResetAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────────────
  users               WorkspaceUser[]
  accounts            Account[]
  contacts            Contact[]
  leads               Lead[]
  deals               Deal[]
  activities          Activity[]
  workflows           Workflow[]
  sequences           Sequence[]
  integrations        IntegrationConnection[]
  sequenceEnrollments SequenceEnrollment[]
  notifications       Notification[]
  experiments         Experiment[]
  iqLeads             IqLead[]
  invites             WorkspaceInvite[]
  customEventTypes    CustomEventType[]
  sourceMappings      SourceMapping[]
  fieldMappings       FieldMapping[]
  outreachLeads        OutreachLead[]
  outreachMetrics      OutreachMetric[]
  webhookDeliveryLogs  WebhookDeliveryLog[]
  workflowBranchDefs   WorkflowBranchDef[]
}

// ─── Outreach tracking ────────────────────────────────────────────────────────
// Lightweight lead record created only when a lead first enters an outreach
// sequence. Sourcing and enrichment events are ignored entirely.

model OutreachLead {
  id          String    @id          // "orl_" + 12 random chars
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  // Privacy-first: hashed for cross-tool matching, encrypted for retrieval
  emailHash    String?
  emailEnc     String?
  linkedinHash String?
  linkedinEnc  String?
  phoneHash    String?
  phoneEnc     String?

  // Non-PII display fields
  displayName String  @default("Unknown Lead")
  company     String?
  title       String?

  // Provenance
  firstTool       String   // tool that fired the first sequence-entry event
  firstSequenceAt DateTime // timestamp of sequence entry
  lastEventAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  metrics OutreachMetric[]

  @@unique([workspaceId, emailHash])
  @@unique([workspaceId, linkedinHash])
  @@unique([workspaceId, phoneHash])
  @@index([workspaceId, lastEventAt])
  @@index([workspaceId, firstTool])
}

// Cumulative metrics per (lead × tool × sequence × step × eventType).
// `count` is incremented on each event; no individual event rows are stored.
// sequenceId and stepId default to "" (empty = no sequence/step context).

model OutreachMetric {
  id          String       @id @default(cuid())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
  lead        OutreachLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String

  tool       String
  sequenceId String  @default("") // "" = no sequence context
  stepId     String  @default("") // "" = no step context
  eventType  String

  count   Int      @default(1)
  firstAt DateTime
  lastAt  DateTime

  @@unique([workspaceId, leadId, tool, sequenceId, stepId, eventType])
  @@index([workspaceId, leadId])
  @@index([workspaceId, tool, sequenceId])
  @@index([workspaceId, eventType])
}

// Inbound webhook delivery log — every event received, before processing gates.
// Answers: "Did webhooks arrive?", "What got dropped?", "Where are errors?"
// Rotated after 30 days to keep the table lean.

model WebhookDeliveryLog {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  tool        String    // provider name: "HeyReach", "Lemlist", etc.
  rawEventKey String    // provider's raw event type string (before normalization)
  eventType   String    // normalized IQPipe event type, or "unknown"
  status      String    // "processed" | "dropped_quota" | "dropped_ignored" | "dropped_no_identity" | "error"
  errorMsg    String?   // populated only when status = "error"
  receivedAt  DateTime  @default(now())

  @@index([workspaceId, tool, receivedAt])
  @@index([workspaceId, status, receivedAt])
  @@index([workspaceId, receivedAt])
}

// One row per output port of each branching node (IF/Switch/Router/Filter)
// extracted from imported n8n workflows and Make.com scenarios at sync time.
// Drives branch-aware gap detection and branch-normalized funnel analysis.

model WorkflowBranchDef {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  platform           String   // "n8n" | "make"
  nativeWorkflowId   String   // n8n workflow id or Make scenario id
  workflowName       String

  // Branch node identification
  branchNodeId       String   // node.id (n8n) or module.id as string (Make)
  branchNodeName     String   // node.name or module display name
  branchNodeType     String   // "if" | "switch" | "router" | "filter"
  branchPort         Int      // output index: 0=TRUE/first route, 1=FALSE/second, …
  branchLabel        String   // "TRUE", "FALSE", "Route 1", custom route filter name

  // Human-readable condition context
  conditionSummary   String?  // e.g. "linkedinUrl is not empty"
  conditionRaw       String?  // raw JSON from workflow (capped at 1000 chars)

  // Channel classification for this branch's output path
  primaryChannel     String   @default("unknown") // "email"|"linkedin"|"phone"|"sms"|"mixed"|"unknown"
  downstreamApps     String   @default("[]")       // JSON string[] — apps reachable from this branch
  expectedEventTypes String   @default("[]")       // JSON string[] — event types expected from this branch

  syncedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, platform, nativeWorkflowId, branchNodeId, branchPort])
  @@index([workspaceId])
  @@index([workspaceId, platform, nativeWorkflowId])
}

model Notification {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  type      String
  title     String
  body      String
  severity  String    @default("info") // "info" | "warning" | "error"
  metadata  String?   // JSON: structured payload for actionable notifications
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

model WorkspaceUser {
  id String @id @default(cuid())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  // Role in this workspace
  role            String  @default("owner") // "owner" | "admin" | "analyst" | "readonly"
  isBillingOwner  Boolean @default(false)

  // Per-user preferences
  darkMode          Boolean @default(true)
  weeklyDigest      Boolean @default(true)
  performanceAlerts Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  name        String
  domain      String?
  industry    String?
  employeeCount Int?
  country     String?
  city        String?
  websiteUrl  String?
  lifecycleStage String @default("prospect")
  ownerId     String?

  contacts   Contact[]
  leads      Lead[]
  deals      Deal[]
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  account     Account?  @relation(fields: [accountId], references: [id])
  accountId   String?

  firstName   String
  lastName    String
  email       String?
  phone       String?
  jobTitle    String?
  linkedinUrl String?
  status      String    @default("active")
  ownerId     String?

  leads               Lead[]
  deals               Deal[]
  activities          Activity[]
  sequenceEnrollments SequenceEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  account     Account?  @relation(fields: [accountId], references: [id])
  accountId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  contactId   String?

  // ✅ Updated fields for Import/Sync
  email     String
  fullName  String?
  firstName String?
  lastName  String?
  company   String?
  title     String?
  source    String?   @default("Manual") // Replaced 'leadSource' to match code
  linkedin  String?  // 👈 ADD THIS FIELD
  status       String  @default("new")
  journeySteps String?
  leadScore    Int?
  fitScore     Int?
  ownerId      String?

  activities          Activity[]
  sequenceEnrollments SequenceEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id               String    @id @default(cuid())
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId      String
  account          Account   @relation(fields: [accountId], references: [id])
  accountId        String
  primaryContact   Contact?  @relation(fields: [primaryContactId], references: [id])
  primaryContactId String?

  name              String
  pipeline          String    @default("new_business")
  stage             String    @default("qualification")
  amount            Float?
  currency          String?   @default("EUR")
  expectedCloseDate DateTime?
  probability       Int?
  ownerId           String?

  activities Activity[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?
}

model Activity {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  type        String
  subject     String?
  body        String?
  status      String?
  userId      String?

  account   Account? @relation(fields: [accountId], references: [id])
  accountId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  leadId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workflow {
  id            String    @id @default(cuid())
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId   String
  name          String
  description   String?
  status        String    @default("draft")
  triggerType   String    @default("event")
  triggerConfig String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes WorkflowNode[]
  edges WorkflowEdge[]
}

model WorkflowNode {
  id         String   @id @default(cuid())
  workflow   Workflow @relation(fields: [workflowId], references: [id])
  workflowId String
  type       String
  name       String
  positionX  Float    @default(0)
  positionY  Float    @default(0)
  config     String? // JSON string

  outgoingEdges WorkflowEdge[] @relation("FromNode")
  incomingEdges WorkflowEdge[] @relation("ToNode")
}

model WorkflowEdge {
  id         String   @id @default(cuid())
  workflow   Workflow @relation(fields: [workflowId], references: [id])
  workflowId String

  fromNode   WorkflowNode @relation("FromNode", fields: [fromNodeId], references: [id])
  fromNodeId String

  toNode   WorkflowNode @relation("ToNode", fields: [toNodeId], references: [id])
  toNodeId String

  conditionLabel String?
}

model Sequence {
  id          String   @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  name        String
  description String?
  type        String   @default("outbound")
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequence   Sequence @relation(fields: [sequenceId], references: [id])
  sequenceId String
  stepOrder  Int
  actionType String
  delayHours Int?
  templateId String?
  config     String? // JSON string
}

model SequenceEnrollment {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  sequence    Sequence  @relation(fields: [sequenceId], references: [id])
  sequenceId  String

  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  leadId    String?

  status           String   @default("active")
  currentStepOrder Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model IntegrationConnection {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  provider    String
  status      String    @default("connected")
  authData    String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experiment {
  id             String    @id @default(cuid())
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId    String
  name           String
  status         String    @default("draft") // "draft" | "active" | "paused" | "completed"
  startDate      String?
  endDate        String?
  audienceSize   Int       @default(0)
  splitPct       Int       @default(50)
  kpis           String?   // JSON: string[]
  stackA         String?   // JSON: StackConfig
  stackB         String?   // JSON: StackConfig
  metricsA       String?   // JSON: ExperimentMetrics
  metricsB       String?   // JSON: ExperimentMetrics
  winner         String?   // "A" | "B" | "tie"
  leadAssignment String?   // JSON: { A: string[], B: string[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Privacy-first lead identity ─────────────────────────────────────────────

model IqLead {
  id          String    @id  // "iq_" + 12 random chars, minted on first sight
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Hashed identifiers for cross-tool lookup — SHA-256 HMAC, NOT reversible
  emailHash    String?
  linkedinHash String?
  phoneHash    String?

  // AES-256 encrypted PII — reversible only by workspace owner
  emailEnc    String?
  linkedinEnc String?
  phoneEnc    String?

  // Non-PII metadata stored in clear
  displayName String?   // "J. Smith" — first name + last initial only
  company     String?
  title       String?

  // Anonymous identity (web visitors, pre-identification)
  anonymousId    String?   // session_id or custom anon ID — plain for lookup
  stitchedFromId String?   // IqLead.id of the anonymous record this was merged from

  // GDPR consent tracking (per Art. 6 GDPR lawful basis)
  consentBasis      String?   // "legitimate_interest" | "consent" | "contract" | "vital_interests" | "public_task" | "legal_obligation"
  consentTimestamp  DateTime?
  consentVersion    String?   // e.g. "privacy-policy-v2.1"
  consentSource     String?   // which tool/source captured consent

  // Right to erasure (Art. 17 GDPR)
  erasureRequestedAt DateTime?
  erasedAt           DateTime?

  // Enrichment tracking — set on every lead_enriched Touchpoint write
  lastEnrichedAt   DateTime?
  enrichmentSource String?   // "clay" | "clearbit" | "apollo" | "zoominfo" | "pdl" | etc.

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @updatedAt

  touchpoints      Touchpoint[]
  outcomes         Outcome[]
  activitySummary  LeadActivitySummary?

  @@index([workspaceId, emailHash])
  @@index([workspaceId, linkedinHash])
  @@index([workspaceId, phoneHash])
  @@index([workspaceId, anonymousId])
}

model Touchpoint {
  id          String   @id @default(cuid())
  workspaceId String
  iqLeadId    String
  iqLead      IqLead   @relation(fields: [iqLeadId], references: [id])

  tool        String   // "heyreach", "instantly", "hubspot", etc.
  channel     String   // "linkedin" | "email" | "phone" | "sms" | "whatsapp" | "crm" | "enrichment" | "billing"
  eventType   String   // iqpipe standard event type

  experimentId String?  // links to Experiment.id if part of A/B test
  stackVariant String?  // "A" or "B"

  meta        String?  // JSON blob: campaign, sequence, deal name, etc.
  workflowId     String?  // n8n workflowId if this event came via n8n
  stepId         String?  // n8n stepId if this event came via n8n
  sourceType     String   @default("webhook")  // "direct_api" | "webhook" | "n8n_workflow" | "generic_api"
  sourcePriority Int      @default(2)           // 1=direct_api, 2=webhook, 3=n8n_workflow
  consentBasis   String?  // per-event GDPR consent basis (overrides lead-level if set)
  externalId     String?  // namespaced idempotency key: "tool:source-id", e.g. "stripe:evt_xxx"
  recordedAt  DateTime @default(now())

  @@index([workspaceId, iqLeadId])
  @@index([workspaceId, tool])
  @@index([workspaceId, eventType])
  @@index([workspaceId, recordedAt])
  // Fast path for externalId-based dedup (used when a natural event ID is available)
  @@unique([workspaceId, externalId])
  // Composite index for the timestamp-window dedup fallback in recordTouchpoint()
  // covers: WHERE workspaceId=? AND iqLeadId=? AND tool=? AND eventType=? AND recordedAt>=?
  @@index([workspaceId, iqLeadId, tool, eventType, recordedAt])
}

// ── n8n integration layer ────────────────────────────────────────────────────

// Layer 1 dedup: every event arriving via POST /api/webhooks/n8n must carry
// a unique idempotency_key. If the same key is seen again within 30 days the
// event is silently discarded before any DB writes happen.
model IdempotencyRecord {
  id          String   @id @default(cuid())
  workspaceId String
  key         String   // format: "{source_tool}-{external_id}-{event_type}"
  createdAt   DateTime @default(now())

  @@unique([workspaceId, key])
  @@index([workspaceId, createdAt])
}

// Dead-letter queue: validation failures (400) and internal errors (500) that
// exhaust retries land here. Users can inspect and re-trigger from Settings.
model WebhookError {
  id          String    @id @default(cuid())
  workspaceId String
  source      String    // "n8n", "make", or the tool slug
  payload     String    // raw JSON body (capped at 10 000 chars)
  errorCode   String    // "SCHEMA_INVALID" | "CONTACT_MISSING" | "INTERNAL_ERROR" | "AUTH_FAILED"
  errorDetail String    // human-readable description
  retryCount  Int       @default(0)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, resolvedAt])
}

// Async ingestion queue for n8n events. Events are written here synchronously
// (202 Accepted) and processed in the background by n8nQueueProcessor.ts.
// Supports workflow- and step-level attribution for performance tracking.
model N8nQueuedEvent {
  id             String    @id @default(cuid())
  workspaceId    String
  workflowId     String    // n8n workflow ID or user-defined name
  stepId         String?   // n8n node/step name that emitted the event
  sourceApp      String    // iqpipe tool slug (e.g. "salesflare", "intercom")
  externalId     String    // tool-native contact or record ID
  eventType      String    // iqpipe standard event type
  contact        String    // JSON: { email, linkedin_url, phone, first_name, last_name, company, title }
  meta           String?   // JSON: arbitrary key-value pairs
  idempotencyKey String    // sha256(sourceApp:externalId:eventType:timeBucket) — 5-min window
  sourceType     String   @default("n8n_workflow") // "direct_api" | "webhook" | "n8n_workflow"
  sourcePriority Int      @default(3)
  eventClass     String?  // "outcome" | "process" — set at ingestion time

  // Processing state machine
  status         String    @default("pending") // pending | processing | done | failed
  attempts       Int       @default(0)
  lastError      String?
  nextRetryAt    DateTime?

  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status, nextRetryAt])
  @@index([workspaceId, workflowId])
  @@index([workspaceId, sourceApp])
  @@index([workspaceId, createdAt])
}

model Outcome {
  id          String   @id @default(cuid())
  workspaceId String
  iqLeadId    String
  iqLead      IqLead   @relation(fields: [iqLeadId], references: [id])

  type        String   // "reply_received" | "meeting_booked" | "deal_created" | "deal_won" | "deal_lost"
  value       Float?   // deal amount
  currency    String?

  // Attribution fields
  reportingTool      String   // tool that fired this outcome event
  firstTouchTool     String?  // first tool to meaningfully contact this lead
  lastTouchTool      String?  // last tool to interact before this outcome
  attributedTools    String?  // JSON: string[] — all tools with touchpoints before outcome
  attributedChannels String?  // JSON: string[] — all channels used

  experimentId String?  // if part of A/B test
  stackVariant String?  // "A" or "B" — which stack gets attribution credit
  workflowId     String?  // n8n workflow that was last-touch before outcome
  stepId         String?  // n8n step within that workflow

  meta        String?  // JSON
  recordedAt  DateTime @default(now())

  @@index([workspaceId, type])
  @@index([workspaceId, iqLeadId])
  @@index([workspaceId, recordedAt])
}

// ── Web Push subscriptions ──────────────────────────────────────────────────

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String

  // Web Push subscription object fields
  endpoint    String   @unique
  p256dh      String   // client public key
  auth        String   // auth secret

  // User-configurable event preferences (JSON: string[])
  // null = all events; explicit array = only listed types
  eventTypes  String?  // JSON: string[] | null

  // Rate-limiting: track last sent times per type
  lastSentAt  DateTime?
  sentCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
}

model MakeConnection {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  apiKeyEnc     String
  region        String    @default("us1")   // "us1" | "eu1" | "eu2"
  teamId        String?                     // Make team ID for /scenarios queries
  organizationId String?
  status        String    @default("connected")
  lastSyncAt    DateTime?
  lastError     String?
  scenarioCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MakeScenarioMeta {
  id              String    @id @default(cuid())
  workspaceId     String
  makeId          String    // Make scenario ID (numeric, stored as string)
  name            String
  active          Boolean   @default(false)
  teamId          String?
  appsUsed        String    @default("[]")   // JSON: string[]
  moduleTypes     String    @default("[]")   // JSON: string[]
  moduleCount     Int       @default(0)
  triggerType     String    @default("schedule")
  lastUpdatedAt   DateTime?
  syncedAt        DateTime  @default(now())
  execSyncEnabled Boolean   @default(true)
  eventFilter     String?   // JSON: { enabled, apps, eventTypes, defaultEventType }

  // ── Workflow diff tracking ────────────────────────────────────────────────
  structureHash    String?   // SHA-256 of sorted module types; changes on structural edit
  lastChangeAt     DateTime? // when structureHash last changed
  lastChangeSummary String?  // human-readable diff: "Added: HubSpot. Removed: Slack."

  @@unique([workspaceId, makeId])
  @@index([workspaceId])
}

model N8nConnection {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  baseUrl         String
  apiKeyEnc       String
  authType        String    @default("apikey")
  status          String    @default("connected")
  lastSyncAt      DateTime?
  lastError       String?
  workflowCount   Int       @default(0)
  lastExecPollAt  DateTime?  // last time we polled /executions across all workflows
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model N8nWorkflowMeta {
  id               String    @id @default(cuid())
  workspaceId      String
  n8nId            String
  name             String
  active           Boolean   @default(false)
  tags             String    @default("[]")
  appsUsed         String    @default("[]")
  nodeTypes        String    @default("[]")
  nodeCount        Int       @default(0)
  triggerType      String    @default("manual")
  description      String?
  lastUpdatedAt    DateTime?
  syncedAt         DateTime  @default(now())
  lastExecCursor   String?   // most recent processed execution ID (incremental polling cursor)
  eventFilter      String?   // JSON: { enabled, apps: string[], eventTypes: string[] }
  execSyncEnabled  Boolean   @default(true)  // whether to poll executions for this workflow

  // ── Workflow diff tracking ────────────────────────────────────────────────
  structureHash    String?   // SHA-256 of sorted node types+names; changes on structural edit
  lastChangeAt     DateTime? // when structureHash last changed
  lastChangeSummary String?  // human-readable diff: "Added: HubSpot. Removed: Slack."

  @@unique([workspaceId, n8nId])
  @@index([workspaceId])
}

// ── Workflow Mirror ──────────────────────────────────────────────────────────
// One mirror config per imported automation. Tracks per-automation app
// connections, event selections, and the correlation key used to match
// automation executions against direct app events.

model WorkflowMirror {
  id              String   @id @default(cuid())
  workspaceId     String
  workflowId      String   // FK to N8nWorkflowMeta.id or MakeScenarioMeta.id
  platform        String   // "n8n" | "make"
  correlationKey  String?  // "email" | "domain" | "phone"
  unknownMappings String   @default("{}") // JSON: { "HTTP Request": "hubspot" }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appConnections  WorkflowAppConnection[]

  @@unique([workspaceId, workflowId])
  @@index([workspaceId])
}

// Per-automation, per-app credential store and connection status.
model WorkflowAppConnection {
  id              String    @id @default(cuid())
  workspaceId     String
  mirrorId        String
  appKey          String    // "hubspot" | "pipedrive" | "instantly" etc.
  connectionType  String    // "webhook" | "polling"
  credentialEnc   String?   // encrypted API key (polling apps)
  webhookSecret   String?   // webhook signing secret (webhook apps)
  status          String    @default("pending") // "pending" | "connected" | "error"
  lastEventAt     DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mirror          WorkflowMirror  @relation(fields: [mirrorId], references: [id], onDelete: Cascade)
  observedEvents  ObservedEvent[]

  @@unique([mirrorId, appKey])
  @@index([workspaceId])
}

// Which events the user chose to observe per app per automation.
model ObservedEvent {
  id           String   @id @default(cuid())
  connectionId String
  appKey       String
  eventKey     String   // technical event key e.g. "deal.creation"
  label        String   // user-facing label e.g. "Deal created"
  createdAt    DateTime @default(now())

  connection   WorkflowAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, eventKey])
}

// Raw inbound events received from direct app webhooks.
model AppEvent {
  id               String    @id @default(cuid())
  workspaceId      String
  appKey           String
  mirrorId         String?   // resolved mirror (set after correlation)
  eventKey         String    // e.g. "deal.creation"
  correlationValue String?   // extracted email / domain / phone
  payload          String    // raw JSON payload from the app
  receivedAt       DateTime  @default(now())
  correlatedAt     DateTime?

  correlations     CorrelationResult[]

  @@index([workspaceId, appKey])
  @@index([workspaceId, correlationValue])
  @@index([receivedAt])
}

// Cross-reference between an n8n/make execution event and a direct app event.
model CorrelationResult {
  id               String   @id @default(cuid())
  workspaceId      String
  mirrorId         String
  n8nEventId       String?  // N8nQueuedEvent.id — null for Make
  appEventId       String
  appKey           String
  correlationKey   String   // "email" | "domain" | "phone"
  correlationValue String   // the matched value
  verified         Boolean  @default(false)
  discrepancy      String?  // JSON: fields that differ
  matchedAt        DateTime @default(now())

  appEvent         AppEvent @relation(fields: [appEventId], references: [id])

  @@index([workspaceId, mirrorId])
  @@index([correlationValue])
  @@index([matchedAt])
}

// ── Workspace invites ──────────────────────────────────────────────────────────

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  email       String
  role        String    @default("analyst") // "admin" | "analyst" | "readonly"
  token       String    @unique @default(cuid())
  invitedById String    // User.id of the inviter
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([token])
}

// ── Report Studio ─────────────────────────────────────────────────────────────
// Stores published report snapshots with a public share token.

model PublicReport {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  workspaceId String
  reportType  String    // "snapshot" | "funnel" | "digest" | "revenue"
  cardFormat  String    @default("linkedin")
  period      String    @default("30d")
  insight     String?   // AI-generated text
  data        String    // JSON blob (serialised ReportData)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([workspaceId])
  @@index([token])
}

// ── Custom Event Types ────────────────────────────────────────────────────────
// Workspaces on Growth/Agency can define their own event taxonomy for
// non-standard sources (web visits, internal DBs, custom APIs).

model CustomEventType {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  key         String    // e.g. "page_viewed" — used in API calls
  label       String    // e.g. "Page Viewed" — shown in UI
  channel     String    @default("custom")  // "web" | "email" | "crm" | "custom" etc.
  category    String    @default("signal")  // "signal" | "outcome"
  description String?
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// ── Source Mappings ───────────────────────────────────────────────────────────
// When IQPipe encounters unknown n8n/Make nodes, users can map them to a named
// source. Saved mappings are applied to all future events from that node type.

model SourceMapping {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  nodeType    String    // e.g. "n8n-nodes-base.httpRequest" | "n8n-nodes-base.postgres"
  platform    String    @default("n8n")    // "n8n" | "make" | "custom"
  appKey      String    // user-defined slug e.g. "internal-crm"
  appLabel    String    // user-facing name e.g. "Internal CRM"
  channel     String    @default("custom") // channel to assign events from this source
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, platform, nodeType])
  @@index([workspaceId])
}

// ── Field Mappings ────────────────────────────────────────────────────────────
// Stores learned and manually-overridden mappings from raw payload paths to
// IQPipe's canonical contact schema fields (e.g. "data.email_addr" → "contact.email").
// Powers the schema-resilient event normalization layer in fieldDetector.ts.

model FieldMapping {
  id              String    @id @default(cuid())
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId     String
  source          String    // tool slug e.g. "clay", "instantly", "hubspot"
  rawPath         String    // dot-path in original payload e.g. "data.contact.email_address"
  canonicalField  String    // "contact.email" | "contact.phone" | "contact.linkedin" | etc.
  confidence      Float     // 0.0 – 1.0
  detectionMethod String    // "value_pattern" | "field_name" | "combined" | "manual"
  isOverride      Boolean   @default(false) // manually set by workspace user
  isRejected      Boolean   @default(false) // user marked this mapping as wrong
  overriddenBy    String?   // userId if isOverride = true
  useCount        Int       @default(0)     // times this mapping was used
  lastSeenAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workspaceId, source, rawPath])
  @@index([workspaceId, source])
  @@index([workspaceId, canonicalField])
}

// ── Deferred Jobs ─────────────────────────────────────────────────────────────
// Lightweight polling-based job queue. Replaces setTimeout() for deferred
// checks that must survive server restarts (e.g. 4-hour at-risk alerts).
// Polled every 2 minutes by deferredJobRunner.ts in syncPoller.

model DeferredJob {
  id          String    @id @default(cuid())
  workspaceId String
  type        String    // "at_risk_check" | future job types
  payload     String    // JSON: job-specific data (iqLeadId, etc.)
  runAt       DateTime  // earliest execution time
  status      String    @default("pending") // "pending" | "done" | "skipped" | "failed"
  attempts    Int       @default(0)
  result      String?   // JSON: outcome written after execution
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, runAt])           // primary poll index
  @@index([workspaceId, type, status])
}

// ── Pipeline Intelligence ─────────────────────────────────────────────────────
// Materialized read model computed by the activitySummarizer worker.
// One row per IqLead. Updated incrementally on every Touchpoint write
// and by a full-refresh background job every 6 hours.
// Replaces on-the-fly table scans in workflowHealth.ts.

model LeadActivitySummary {
  id          String   @id @default(cuid())
  workspaceId String
  iqLeadId    String   @unique
  iqLead      IqLead   @relation(fields: [iqLeadId], references: [id], onDelete: Cascade)

  // ── Import timing ──────────────────────────────────────────────────────────
  importedAt  DateTime?   // = first lead_imported Touchpoint.recordedAt

  // ── Signal-to-Action Latency ───────────────────────────────────────────────
  // Time between importedAt and the first intentional outreach Touchpoint.
  firstOutreachAt DateTime?
  latencyHours    Float?      // null = no outreach yet
  latencyBucket   String?     // "sub4h" | "4to24h" | "1to3d" | "3to7d" | "over7d"

  // ── Cross-Tool Contact Frequency ───────────────────────────────────────────
  touchCount7d       Int    @default(0)   // outreach-only events, rolling 7-day window
  touchCount30d      Int    @default(0)
  touchCountAllTime  Int    @default(0)
  lastOutreachAt     DateTime?            // most recent outreach Touchpoint
  frequencyBucket    String?              // "0" | "1-2" | "3-5" | "6-9" | "10+"
  touchBreakdown7d   String?              // JSON: { "heyreach": 8, "instantly": 3 }

  // ── Funnel Stage (sequential waterfall) ───────────────────────────────────
  // Only advances forward. A lead cannot be "engaged" without first being "contacted".
  // Values: imported | enriched | contacted | engaged | replied | meeting | won
  funnelStage         String   @default("imported")
  funnelStageUpdatedAt DateTime?

  // ── Enrichment Freshness ──────────────────────────────────────────────────
  lastEnrichedAt    DateTime?
  enrichmentAgeDays Float?      // (now - lastEnrichedAt) in days; null = never enriched
  enrichmentBucket  String?     // "fresh" | "aging" | "stale" | "very_stale" | "never"
  // fresh < 30d | aging 30–90d | stale 90–180d | very_stale > 180d

  // ── Silent Pipeline Flag ──────────────────────────────────────────────────
  // true when importedAt > 7 days ago AND touchCountAllTime = 0
  isSilent        Boolean  @default(false)
  silentSince     DateTime?  // when the 7-day threshold was crossed with no outreach

  // ── ICP Fit Score ─────────────────────────────────────────────────────────
  // Computed from IqLead.title + IqLead.company against workspace ICP profile.
  // Recomputed by icpScoringWorker when ICP profile changes or on enrichment.
  icpScore  Int?      // 0–100; null = no ICP profile defined
  icpGrade  String?   // "hot" | "warm" | "cold"; null = no ICP profile

  // ── Churn Probability ─────────────────────────────────────────────────────
  // Probability (0.0–1.0) that this lead will NOT convert from current stage.
  // Computed by churnProbabilityService from workspace historical funnel rates.
  churnProbability  Float?   // null = insufficient data

  // ── Worker metadata ───────────────────────────────────────────────────────
  computedAt  DateTime  @default(now()) @updatedAt

  @@index([workspaceId, latencyBucket])
  @@index([workspaceId, frequencyBucket])
  @@index([workspaceId, funnelStage])
  @@index([workspaceId, enrichmentBucket])
  @@index([workspaceId, isSilent])
  @@index([workspaceId, lastOutreachAt])
  @@index([workspaceId, importedAt])
}

// ── Knowledge Base ─────────────────────────────────────────────────────────────
// Global curated articles (guides, playbooks, troubleshooting, reference).
// Not workspace-scoped — same content for all workspaces.
// Behavior (searches, views, votes) is tracked per-workspace for learning.

model KbArticle {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  summary         String    // one-sentence quick answer (for list views)
  body            String    // markdown — full deep-dive content
  category        String    // "guide" | "playbook" | "troubleshooting" | "reference" | "concept"
  tags            String    // JSON string[] e.g. ["schema-drift","n8n","identity"]
  useCase         String    // JSON string[] e.g. ["lead_enrichment","gtm_workflow"]
  platform        String    // JSON string[] e.g. ["n8n","make","any"]
  difficulty      String    @default("beginner") // "beginner" | "intermediate" | "advanced"
  viewCount       Int       @default(0)
  helpfulCount    Int       @default(0)
  notHelpfulCount Int       @default(0)
  featured        Boolean   @default(false)
  published       Boolean   @default(true)
  relatedSlugs    String    @default("[]") // JSON string[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  feedback        KbArticleFeedback[]

  @@index([category])
  @@index([featured])
}

// Tracks every search query for learning (surface gaps, improve ranking).
model KbSearchEvent {
  id               String    @id @default(cuid())
  workspaceId      String?   // null = unauthenticated
  query            String
  resultsCount     Int
  clickedArticleId String?   // article the user clicked (null = no click)
  resolved         Boolean   @default(false) // user marked as helpful or clicked
  createdAt        DateTime  @default(now())

  @@index([workspaceId])
  @@index([query])
  @@index([createdAt])
}

// Per-article helpful/not-helpful votes, optional comment.
model KbArticleFeedback {
  id          String     @id @default(cuid())
  article     KbArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  workspaceId String?
  helpful     Boolean
  comment     String?
  createdAt   DateTime   @default(now())

  @@index([articleId])
  @@index([workspaceId])
}
